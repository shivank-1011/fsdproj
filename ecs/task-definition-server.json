{
  "family": "fsdproj-server-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "fsdproj-server",
      "image": "ACCOUNT_ID.dkr.ecr.eu-north-1.amazonaws.com/fsdproj-server:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5001,
          "hostPort": 5001,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "PORT", "value": "5001" },
        { "name": "NODE_ENV", "value": "production" }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:ACCOUNT_ID:secret:fsdproj/DATABASE_URL"
        },
        {
          "name": "DIRECT_URL",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:ACCOUNT_ID:secret:fsdproj/DIRECT_URL"
        },
        {
          "name": "ACCESS_TOKEN_SECRET",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:ACCOUNT_ID:secret:fsdproj/ACCESS_TOKEN_SECRET"
        },
        {
          "name": "REFRESH_TOKEN_SECRET",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:ACCOUNT_ID:secret:fsdproj/REFRESH_TOKEN_SECRET"
        },
        {
          "name": "CLOUDINARY_CLOUD_NAME",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:ACCOUNT_ID:secret:fsdproj/CLOUDINARY_CLOUD_NAME"
        },
        {
          "name": "CLOUDINARY_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:ACCOUNT_ID:secret:fsdproj/CLOUDINARY_API_KEY"
        },
        {
          "name": "CLOUDINARY_API_SECRET",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:ACCOUNT_ID:secret:fsdproj/CLOUDINARY_API_SECRET"
        },
        {
          "name": "GOOGLE_CLIENT_ID",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:ACCOUNT_ID:secret:fsdproj/GOOGLE_CLIENT_ID"
        },
        {
          "name": "GOOGLE_CLIENT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:ACCOUNT_ID:secret:fsdproj/GOOGLE_CLIENT_SECRET"
        },
        {
          "name": "CLIENT_URL",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:ACCOUNT_ID:secret:fsdproj/CLIENT_URL"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/fsdproj-server",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:5001/ || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 40
      }
    }
  ]
}
